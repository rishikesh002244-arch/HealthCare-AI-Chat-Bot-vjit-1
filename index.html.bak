<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HealthCare AI ChatBot</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            overflow: hidden;
            background-color: #0e1117;
            font-family: 'Inter', sans-serif;
            color: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .loading {
            text-align: center;
        }
        .spinner {
            width: 50px;
            height: 50px;
            border: 5px solid rgba(255, 255, 255, 0.1);
            border-top-color: #ff4b4b;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }
        @keyframes spin { 
            to { transform: rotate(360deg); } 
        }
        h1 { margin-bottom: 10px; font-weight: 600; }
        p { color: #a1a1aa; }
        iframe {
            width: 100%;
            height: 100%;
            border: none;
            display: none;
        }
    </style>
</head>
<body>
    <div class="loading" id="loading">
        <div class="spinner"></div>
        <h1>HealthCare AI ChatBot</h1>
        <p>Initializing application environment... please wait.</p>
    </div>
    
    <!-- We will inject the Streamlit URL here once deployed -->
    <iframe id="app-frame" allow="microphone; camera; geolocation"></iframe>

    <script>
        // Load the actual Streamlit app seamlessly into the iframe
        document.getElementById('app-frame').src = "https://appcom-jc2zyevnb6h7raeup5bkj4.streamlit.app/?embed=true";
        document.getElementById('app-frame').onload = function() {
            document.getElementById('app-frame').style.display = "block";
            document.getElementById('loading').style.display = "none";
        };
    </script>
</body>
</html>
